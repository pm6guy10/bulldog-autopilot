"use client";
import { useState } from 'react';

// Mock data - in the future, this would come from your database
const caseMetrics = {
  highRiskViolations: 2,
  constructiveDenials: 4,
  privilegeLogFailures: 2,
  averageDelay: 0,
};

export default function DraftPage() {
  const [step, setStep] = useState(1);
  const [selectedArgs, setSelectedArgs] = useState([]);
  const [tone, setTone] = useState('professional');
  const [draft, setDraft] = useState('');
  const [isLoading, setIsLoading] = useState(false);

  // Wigdor Intelligence: Analyzes metrics to suggest arguments
  const recommendedArgs = [];
  if (caseMetrics.constructiveDenials > 2) {
    recommendedArgs.push({ id: 'bad_faith', title: 'Argue a Pattern of Bad Faith', description: `Leverage the ${caseMetrics.constructiveDenials} constructive denials to demonstrate a pattern of evasion.` });
  }
  if (caseMetrics.privilegeLogFailures > 0) {
    recommendedArgs.push({ id: 'privilege_waiver', title: 'Argue Waiver of Privilege', description: `The ${caseMetrics.privilegeLogFailures} privilege log failures suggest a waiver of claimed exemptions.` });
  }
  if (caseMetrics.highRiskViolations > 0) {
    recommendedArgs.push({ id: 'in_camera_review', title: 'Demand In Camera Review', description: `The ${caseMetrics.highRiskViolations} high-risk violations necessitate judicial review of the withheld records.` });
  }

  const handleToggleArg = (id) => {
    setSelectedArgs(prev => prev.includes(id) ? prev.filter(argId => argId !== id) : [...prev, id]);
  };

  const generateDraft = async () => {
    setIsLoading(true);
    // In a real app, you'd send the selectedArgs and tone to your API
    // For this example, we'll simulate the AI response.
    const response = await fetch('/api/draft', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ metrics: caseMetrics, arguments: selectedArgs, tone: tone }),
    });
    const data = await response.json();
    setDraft(data.draft);
    setIsLoading(false);
    setStep(3);
  };

  return (
    <main className="min-h-screen p-6 pb-28 lg:max-w-4xl lg:mx-auto">
      <h1 className="glow-text text-3xl font-bold mb-6 text-center">Smart Draft Assistant</h1>

      {/* Step 1: Select Arguments */}
      {step === 1 && (
        <div className="card-enhanced">
          <h2 className="text-xl font-semibold mb-1">Step 1: Select Your Core Arguments</h2>
          <p className="text-gray-400 mb-4">Our Wigdor Intelligence engine has analyzed the case data and recommends focusing on these key points.</p>
          <div className="space-y-3">
            {recommendedArgs.map(arg => (
              <div key={arg.id} onClick={() => handleToggleArg(arg.id)}
                className={`p-4 border rounded-lg cursor-pointer transition-all ${selectedArgs.includes(arg.id) ? 'bg-cyan-900 border-cyan-400' : 'border-gray-600 hover:border-gray-400'}`}>
                <p className="font-bold">{arg.title}</p>
                <p className="text-sm text-gray-300">{arg.description}</p>
              </div>
            ))}
          </div>
          <button onClick={() => setStep(2)} className="btn w-full mt-6" disabled={selectedArgs.length === 0}>
            Next: Set Tone
          </button>
        </div>
      )}

      {/* Step 2: Set Tone */}
      {step === 2 && (
        <div className="card-enhanced">
          <h2 className="text-xl font-semibold mb-4">Step 2: Set the Tone</h2>
          <div className="space-y-3">
            <div onClick={() => setTone('professional')} className={`p-4 border rounded-lg cursor-pointer transition-all ${tone === 'professional' ? 'bg-cyan-900 border-cyan-400' : 'border-gray-600 hover:border-gray-400'}`}>
              <p className="font-bold">Firm but Professional</p>
              <p className="text-sm text-gray-300">Clearly outlines failures and requests remedies without overly aggressive language.</p>
            </div>
            <div onClick={() => setTone('aggressive')} className={`p-4 border rounded-lg cursor-pointer transition-all ${tone === 'aggressive' ? 'bg-cyan-900 border-cyan-400' : 'border-gray-600 hover:border-gray-400'}`}>
              <p className="font-bold">Aggressively Seek Sanctions</p>
              <p className="text-sm text-gray-300">Uses forceful language to assert bad faith and explicitly demand monetary sanctions.</p>
            </div>
          </div>
          <div className="flex gap-4 mt-6">
            <button onClick={() => setStep(1)} className="btn-secondary w-full">Back</button>
            <button onClick={generateDraft} className="btn w-full" disabled={isLoading}>
              {isLoading ? 'Generating...' : 'Generate Draft'}
            </button>
          </div>
        </div>
      )}

      {/* Step 3: View Draft */}
      {step === 3 && (
        <div className="card-enhanced">
          <h2 className="text-xl font-semibold mb-4">Step 3: Your Generated Draft</h2>
          <textarea readOnly value={draft} className="w-full h-96 p-3 bg-gray-900 border border-gray-600 rounded-lg text-gray-200 font-mono text-sm"></textarea>
          <div className="flex gap-4 mt-6">
            <button onClick={() => setStep(2)} className="btn-secondary w-full">Back & Refine</button>
            <button onClick={() => navigator.clipboard.writeText(draft)} className="btn w-full">
              Copy to Clipboard
            </button>
          </div>
        </div>
      )}
    </main>
  );
}
